# Required for indexed token data, holders, activity, writes, and filtering.
NUXT_INDEXER_URL=http://127.0.0.1:42069

# Optional. Public browser RPC used only for live machine payload/name reads.
NUXT_PUBLIC_MACHINE_RPC_URL=https://ethereum-rpc.publicnode.com

# Optional. Public read RPCs for layers.evm ENS reads. Falls back to the machine RPC when unset.
NUXT_PUBLIC_EVM_CHAINS_MAINNET_RPCS=
