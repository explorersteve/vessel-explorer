# Required for the Etherscan fallback activity and transfer routes.
NUXT_ETHERSCAN_KEY=

# Required for indexed token data, holders, writes, and /all filtering.
NUXT_INDEXER_URL=http://127.0.0.1:42069

# Optional browser RPC fallbacks for on-chain reads.
NUXT_PUBLIC_EVM_CHAINS_MAINNET_RPC1=https://ethereum-rpc.publicnode.com
NUXT_PUBLIC_EVM_CHAINS_MAINNET_RPC2=https://rpc.flashbots.net
NUXT_PUBLIC_EVM_CHAINS_MAINNET_RPC3=https://rpc.ankr.com/eth
