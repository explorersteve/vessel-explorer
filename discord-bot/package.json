{
  "name": "@vessel-explorer/discord-bot",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "test": "tsc && node --test \"dist/**/*.test.js\"",
    "kamal:setup": "set -a && . ./.env.production && set +a && kamal setup",
    "kamal:deploy": "set -a && . ./.env.production && set +a && kamal deploy",
    "kamal:sh": "set -a && . ./.env.production && set +a && kamal app exec -i --reuse sh"
  },
  "dependencies": {
    "viem": "^2.48.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
